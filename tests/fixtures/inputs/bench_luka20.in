% Condensed detachment in propositional calculus - Lukasiewicz basis
% Derives a known theorem - medium difficulty

assign(max_seconds, 30).

formulas(sos).
  P(i(x, i(y, x))).
  P(i(i(x, i(y, z)), i(i(x, y), i(x, z)))).
  P(i(i(n(x), n(y)), i(y, x))).
  -P(x) | -P(i(x, y)) | P(y).
end_of_list.

formulas(goals).
  P(i(a, a)).
end_of_list.
